# TradeMind AI Paper Trading MVP Environment Variables
# Create a .env file locally with these values to configure your local setup.

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Settings (For Phase 1 local MySQL/PostgreSQL transitions. Standard SQL logs use JSON DB in AI Studio container).
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=trademind_ai

# API / Simulation Configuration
MARKET_DATA_MODE=mock # 'mock' or 'live' once official Zerodha/Upstox keys are available

# Host URL
FRONTEND_URL=http://localhost:3000

# AI Services (Required for Phase 2 smart agents)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
